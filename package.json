{
  "name": "stampy",
  "version": "0.0.1",
  "private": true,
  "description": "위치 기반 관광 도장 수집 앱 (한국관광공사 TourAPI + Kakao Maps)",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "harness:check": "node scripts/harness-check.mjs",
    "map-route-proxy": "node scripts/kakao-route-proxy.mjs",
    "test": "jest",
    "quality:fast": "npm-run-all -s typecheck lint format:check",
    "quality": "npm-run-all -s quality:fast test harness:check",
    "session": "node scripts/session-state.mjs",
    "prepare": "husky"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/src/**/__tests__/**/*.test.@(ts|tsx)"
    ]
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.0",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.0",
    "expo-location": "~18.0.0",
    "expo-router": "~4.0.0",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.0",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "react-native-webview": "13.12.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "lint-staged": "^17.0.7",
    "npm-run-all2": "^9.0.1",
    "prettier": "^3.8.3",
    "puppeteer": "^25.1.0",
    "typescript": "~5.3.3"
  }
}
