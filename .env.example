EXPO_PUBLIC_TOUR_API_KEY=
EXPO_PUBLIC_KAKAO_JS_KEY=
EXPO_PUBLIC_MAP_ROUTE_PROXY_URL=http://localhost:8787/map-route
# false uses mock repositories; true uses HTTP repositories and requires EXPO_PUBLIC_TOUR_API_KEY.
EXPO_PUBLIC_USE_REAL_API=false

# Server-side only for `npm run map-route-proxy`; do not expose in app code.
KAKAO_REST_API_KEY=
MAP_ROUTE_PROXY_HOST=127.0.0.1
MAP_ROUTE_PROXY_PORT=8787
